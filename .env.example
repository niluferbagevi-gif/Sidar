# ─────────────────────────────────────────────
# Sidar Project — Çevre Değişkenleri Örneği
# Bu dosyayı .env olarak kopyalayın ve doldurun:
#   cp .env.example .env
#
# Bu şablon platformdan bağımsız güvenli başlangıç değerleri içerir.
# Donanımınıza göre (özellikle GPU ve timeout değerleri) özelleştirin.
# ─────────────────────────────────────────────

# ─── AI Sağlayıcısı ──────────────────────────
# "ollama" (yerel), "gemini" (bulut), "openai" (bulut) veya "anthropic" (bulut)
AI_PROVIDER=ollama

# ─── Ollama ──────────────────────────────────
OLLAMA_URL=http://localhost:11434/api
# Ollama API zaman aşımı (saniye)
# Model boyutu/ağ durumuna göre artırabilirsiniz.
OLLAMA_TIMEOUT=30
CODING_MODEL=qwen2.5-coder:7b
TEXT_MODEL=gemma2:9b

# ─── Google Gemini (opsiyonel) ────────────────
# Google AI Studio (aistudio.google.com) üzerinden API key oluşturup buraya yapıştırın
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ─── OpenAI (opsiyonel) ──────────────────────
# platform.openai.com/api-keys üzerinden API key oluşturup buraya yapıştırın
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT=60

# ─── Anthropic Claude (opsiyonel) ─────────────
# console.anthropic.com/settings/keys üzerinden API key oluşturup buraya yapıştırın
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest
ANTHROPIC_TIMEOUT=60

# ─── Erişim Seviyesi (OpenClaw) ───────────────
# restricted : Yalnızca okuma ve denetim
# sandbox    : Okuma + /temp dizinine yazma
# full       : Tam erişim — yalnızca bilinçli olarak açın
ACCESS_LEVEL=sandbox
# Web UI / API Basic Auth şifresi (opsiyonel, boşsa auth kapalı)
# Web UI/API için güçlü bir parola belirleyin (örn: UzunRastgeleSifre123!)
API_KEY=

# Otonomi webhook/cron koruma secret — proaktif webhook/cron uçları için paylaşılan gizli anahtar
AUTONOMY_WEBHOOK_SECRET=
# Proaktif cron tetikleyicisinin varsayılan promptu
AUTONOMOUS_CRON_PROMPT=Planlı sağlık ve operasyon özeti üret
# Gece döngüsü: hafıza konsolidasyonu ve eski RAG embedding temizliği
ENABLE_NIGHTLY_MEMORY_PRUNING=false
NIGHTLY_MEMORY_INTERVAL_SECONDS=86400
NIGHTLY_MEMORY_IDLE_SECONDS=1800
NIGHTLY_MEMORY_KEEP_RECENT_SESSIONS=2
NIGHTLY_MEMORY_SESSION_MIN_MESSAGES=12
NIGHTLY_MEMORY_RAG_KEEP_RECENT_DOCS=2
# Swarm/federation çağrılarında paylaşılan imza anahtarı — harici ajan federasyonu için
SWARM_FEDERATION_SHARED_SECRET=

# ─── GitHub (opsiyonel) ───────────────────────
# github.com/settings/tokens adresinden repo erişimli Personal Access Token üretip buraya yazın
GITHUB_TOKEN=
GITHUB_REPO=kullanici/depo-adi
# GitHub webhook imza doğrulaması için secret — GitHub webhook ayarlarından üretin
GITHUB_WEBHOOK_SECRET=

# ─── Donanım & GPU ───────────────────────────
# true = PyTorch CUDA varsa GPU kullan; false = her zaman CPU
USE_GPU=false

# Birden fazla GPU varsa hangi cihaz kullanılsın (0-indexed)
GPU_DEVICE=0

# Çoklu GPU dağıtık mod (çoğu kurulumda false bırakın)
MULTI_GPU=false

# Embedding/model yüklemeleri için maksimum VRAM fraksiyonu (0.1 – 1.0)
GPU_MEMORY_FRACTION=0.8

# LLM çalışma belleği için ayrılan VRAM fraksiyonu (0.1 – 1.0)
LLM_GPU_MEMORY_FRACTION=0.8

# RAG/embedding iş akışı için ayrılan VRAM fraksiyonu (0.1 – 1.0)
RAG_GPU_MEMORY_FRACTION=0.3

# FP16 mixed precision → ChromaDB embedding'de VRAM tasarrufu
# Yeni nesil GPU'larda true tercih edilebilir; sorun yaşarsanız false kullanın
GPU_MIXED_PRECISION=false

# ─── HuggingFace ─────────────────────────────
# Model ilk indirildikten sonra HF_HUB_OFFLINE=1 yapın:
# → Her açılışta internet kontrolü yapmaz, cache'den hızlıca yükler (~1 dk tasarruf)
# İlk kurulumda veya model güncellemek istediğinizde 0 yapın.
# huggingface.co/settings/tokens adresinden Read token üretip buraya yazın
HF_TOKEN=
HF_HUB_OFFLINE=0

# ─── Uygulama ────────────────────────────────
MAX_MEMORY_TURNS=20
# Özetleme sonrası ham bellekte tutulacak son konuşma turu
MEMORY_SUMMARY_KEEP_LAST=4
RESPONSE_LANGUAGE=tr
DEBUG_MODE=false
# Ortam profili (development/staging/production)
SIDAR_ENV=development

# ReviewerAgent doğrulama aşamasında çalıştırılacak test komutu
REVIEWER_TEST_COMMAND=python -m pytest

# Browser otomasyonu sağlayıcısı: auto, playwright veya selenium
BROWSER_PROVIDER=auto
# Python LSP sunucusu komutu (örn. pyright-langserver / pylsp)
PYTHON_LSP_SERVER=pyright-langserver --stdio
# TypeScript/JavaScript LSP sunucusu komutu
TYPESCRIPT_LSP_SERVER=typescript-language-server --stdio

# ─── Loglama ─────────────────────────────────
LOG_LEVEL=INFO
# Log dosyası yolu (proje köküne göre)
LOG_FILE=logs/sidar_system.log
# Tek log dosyası maksimum boyutu (byte) — varsayılan 10 MB
LOG_MAX_BYTES=10485760
# Yedek log dosyası sayısı
LOG_BACKUP_COUNT=5

# ─── ReAct Döngüsü ───────────────────────────
MAX_REACT_STEPS=10
# İhtiyaca göre artırın (büyük görevler/düşük donanım için)
REACT_TIMEOUT=60
# Alt ajanların kendi içlerinde maksimum ReAct adımı
SUBTASK_MAX_STEPS=5
# AutoHandle kısa komutlarında (örn .status) blocking işlem timeout
AUTO_HANDLE_TIMEOUT=12

# ─── LLM Retry Ayarları ───────────────────────
# LLM sağlayıcı çağrılarında maksimum yeniden deneme sayısı
LLM_MAX_RETRIES=2
# Exponential backoff başlangıç gecikmesi (saniye)
LLM_RETRY_BASE_DELAY=0.4
# Exponential backoff için üst gecikme sınırı (saniye)
LLM_RETRY_MAX_DELAY=4.0

# ─── LiteLLM Gateway (opsiyonel) ────────────
# AI_PROVIDER=litellm yapıldığında tüm LLM trafiği bu gateway üzerinden geçer.
# LiteLLM proxy: https://docs.litellm.ai/docs/proxy_server
LITELLM_GATEWAY_URL=http://localhost:4000
# LiteLLM proxy veya OpenRouter API anahtarını buraya yazın
LITELLM_API_KEY=
# Birincil model: LiteLLM proxy'de tanımlı model adı
LITELLM_MODEL=gpt-4o-mini
# Fallback modeller: virgülle ayrılmış sıralı liste (birincil başarısız olursa denenir)
LITELLM_FALLBACK_MODELS=gpt-4o-mini,claude-3-haiku-20240307
LITELLM_TIMEOUT=60

# ─── Anlamsal Önbellekleme (Semantic Cache, v4.0) ───
# true yapıldığında tekrar eden semantik sorgular Redis cache'den yanıtlanır
# (token maliyetini düşürür, p95 yanıt süresini iyileştirir)
ENABLE_SEMANTIC_CACHE=false
# Kosinus benzerlik eşiği — bu değerin üstünde cache HIT sayılır (0.0–1.0)
SEMANTIC_CACHE_THRESHOLD=0.95
# Cache TTL (saniye) — varsayılan 1 saat
SEMANTIC_CACHE_TTL=3600
# Cache'de tutulacak maksimum öğe sayısı (LRU eviction)
SEMANTIC_CACHE_MAX_ITEMS=500

# ─── pgvector RAG Arka Ucu (v4.0) ───────────
# RAG_VECTOR_BACKEND=chroma (varsayılan) veya pgvector (PostgreSQL)
# pgvector için PostgreSQL bağlantısı DATABASE_URL ile yapılandırılır.
RAG_VECTOR_BACKEND=chroma
PGVECTOR_TABLE=rag_embeddings
PGVECTOR_EMBEDDING_DIM=384
PGVECTOR_EMBEDDING_MODEL=all-MiniLM-L6-v2

# ─── Dağıtık Ajan Event Bus (v4.0) ──────────
# Redis Streams tabanlı; Redis yoksa otomatik olarak bellek içi kuyruğa döner.
SIDAR_EVENT_BUS_CHANNEL=sidar:agent_events
SIDAR_EVENT_BUS_GROUP=sidar:agent_events:cg
SIDAR_EVENT_BUS_DLQ_CHANNEL=sidar:agent_events:dlq

# ─── Gözlemlenebilirlik (OpenTelemetry) ─────
ENABLE_TRACING=false
OTEL_EXPORTER_ENDPOINT=http://localhost:4317
# OTel servis adı (Jaeger/Zipkin'de görünür)
OTEL_SERVICE_NAME=sidar
# FastAPI ve HTTPX otomatik enstrümantasyon (ENABLE_TRACING=true ise etkili)
OTEL_INSTRUMENT_FASTAPI=true
OTEL_INSTRUMENT_HTTPX=true

# ─── Redis (Kalıcı Rate Limiting) ───────────
REDIS_URL=redis://redis:6379/0
# Güvenilir ters proxy IP'leri (virgülle ayrılmış). Boşsa X-Forwarded-For/X-Real-IP başlıkları
# kabul edilmez; direkt bağlantının IP'si kullanılır. Nginx/Traefik arkasındaysa proxy IP'sini girin.
# Örnek: TRUSTED_PROXIES=10.0.0.1,10.0.0.2
TRUSTED_PROXIES=

# ─── API Hız Sınırları (Rate Limiting) ───────
# 60 saniyelik penceredeki istek limitleri
RATE_LIMIT_WINDOW=60
RATE_LIMIT_CHAT=20
RATE_LIMIT_MUTATIONS=60
RATE_LIMIT_GET_IO=30
# RAG dosya yükleme boyut sınırı (byte; varsayılan 50 MB = 52428800)
MAX_RAG_UPLOAD_BYTES=52428800
# /metrics, /metrics/llm, /api/budget için statik Bearer token (boşsa yalnızca admin erişebilir)
# Örnek: METRICS_TOKEN=güçlü-rastgele-bir-token
METRICS_TOKEN=

# ─── Web Arama ───────────────────────────────
# auto, duckduckgo, tavily veya google
SEARCH_ENGINE=auto
# app.tavily.com üzerinden API key oluşturup buraya yapıştırın
TAVILY_API_KEY=
# Google Cloud Console'da Custom Search JSON API key oluşturup buraya yazın
GOOGLE_SEARCH_API_KEY=
# programmablesearchengine.google.com üzerinden Search Engine ID (cx) değerini buraya yazın
GOOGLE_SEARCH_CX=

# DuckDuckGo arama sonucu sayısı (1-10 arası önerilir)
WEB_SEARCH_MAX_RESULTS=5
# URL içerik çekme zaman aşımı (saniye)
WEB_FETCH_TIMEOUT=15
# URL içerik maksimum karakter sınırı
WEB_FETCH_MAX_CHARS=12000
# Yeni ad (öncelikli): scrape bağlam limiti
WEB_SCRAPE_MAX_CHARS=12000

# ─── Paket Bilgi ─────────────────────────────
# PyPI/npm/GitHub API zaman aşımı (saniye)
PACKAGE_INFO_TIMEOUT=12
# Paket sorgu cache süresi (saniye)
PACKAGE_INFO_CACHE_TTL=1800

# ─── RAG — Belge Deposu ──────────────────────
# Belge depolama dizini (proje köküne göre)
RAG_DIR=data/rag
# Arama sonucu sayısı
RAG_TOP_K=3
# Chunk boyutu (karakter)
RAG_CHUNK_SIZE=1000
# Chunk örtüşme miktarı (karakter)
RAG_CHUNK_OVERLAP=200
# Büyük dosya eşiği (karakter) — bu sınırı geçen dosyaları RAG'a ekleme önerilir
RAG_FILE_THRESHOLD=20000

# ─── Bellek Şifrelemesi ──────────────────────
# Boş bırakılırsa şifreleme devre dışı (varsayılan — önerilen genel kullanım).
# Kurumsal/hassas veri için Fernet anahtarı üretin:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Üretilen anahtarı buraya yapıştırın (44 karakter, = ile biter):
# Kurumsal kullanımda Fernet anahtarı üretin: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Kişisel kullanımda boş bırakabilirsiniz (şifreleme devre dışı)
MEMORY_ENCRYPTION_KEY=

# ─── Web Arayüzü ─────────────────────────────
# Dinlenecek adres (0.0.0.0 = tüm arayüzler, localhost = yalnızca yerel)
WEB_HOST=0.0.0.0
# Port numarası (7860 AI uygulamaları için yaygın tercih)
WEB_PORT=7860
# GPU web servisi portu (docker-compose sidar-web-gpu servisi için)
WEB_GPU_PORT=7861

# ─── JWT Kimlik Doğrulama ─────────────────────
# ÜRETİM ORTAMINDA ZORUNLU: Güçlü rastgele bir değer kullanın.
# Oluşturmak için: python -c "import secrets; print(secrets.token_urlsafe(64))"
# Boş bırakılırsa sunucu başlangıcında CRITICAL uyarısı verilir.
JWT_SECRET_KEY=
# HS256 veya RS256 (varsayılan: HS256)
JWT_ALGORITHM=HS256
# Token geçerlilik süresi (gün) — varsayılan: 7
JWT_TTL_DAYS=7

# ─── Observability ───────────────────────────
# Admin panelindeki "Grafana'yı Aç" butonu bu URL'yi kullanır.
# docker-compose ortamında http://grafana:3000 veya dış adres ayarlanabilir.
GRAFANA_URL=http://localhost:3000

# ─── Docker REPL Sandbox ──────────────────────
# CodeManager'ın kod çalıştırma sandbox'ında kullanacağı Docker imajı
# CPU ortamı için python:3.11-alpine önerilir (küçük boyut, hızlı başlangıç)
DOCKER_PYTHON_IMAGE=python:3.11-alpine
# Maksimum Docker sandbox çalışma süresi (saniye) — sonsuz döngü koruması
DOCKER_EXEC_TIMEOUT=10
# Docker zorunlu mod: true ise Docker erişilemezken yerel subprocess fallback engellenir
# Üretim ortamında true olarak ayarlayın
DOCKER_REQUIRED=false
DOCKER_RUNTIME=
DOCKER_ALLOWED_RUNTIMES=,runc,runsc,kata-runtime

# ─── Sandbox Kaynak Kotaları (gelişmiş, opsiyonel) ───
# Aşağıdaki değerler config.py::SANDBOX_LIMITS içinde kullanılır ve CodeManager
# tarafından Docker run çağrısına aktarılır. Varsayılanlar güvenli/dengeli seçilmiştir.
# Yüksek performanslı görevlerde artırabilir; kısıtlı ortamlarda düşürebilirsiniz.
SANDBOX_MEMORY=256m
SANDBOX_CPUS=0.5
SANDBOX_NETWORK=none
SANDBOX_PIDS_LIMIT=64
SANDBOX_TIMEOUT=10

# ─── DLP — Veri Kaybı Önleme (v4.1) ─────────────────────────────────────────
# true: LLM API çağrılarından önce PII/hassas veri maskeler (önerilir)
DLP_ENABLED=true
# true: Maskeleme tespitleri WARNING seviyesinde loglanır
DLP_LOG_DETECTIONS=false

# ─── HITL — Human-in-the-Loop Onay Geçidi (v4.1) ─────────────────────────────
# true: Dosya silme, PR oluşturma gibi yıkıcı işlemler insan onayına sunulur
HITL_ENABLED=false
# Onay bekleme süresi (saniye); bu süre aşılırsa işlem reddedilir
HITL_TIMEOUT_SECONDS=120

# ─── LLM-as-a-Judge Kalite Değerlendirmesi (v4.1) ─────────────────────────────
# true: RAG yanıtları asenkron olarak LLM tabanlı kalite değerlendirmesinden geçirilir
JUDGE_ENABLED=false
# Değerlendirme için kullanılacak model (boşsa TEXT_MODEL kullanılır)
JUDGE_MODEL=
# Değerlendirme sağlayıcısı (ollama, gemini, openai, anthropic, litellm)
JUDGE_PROVIDER=ollama
# Örnekleme oranı: 0.0 = hiç değerlendirme yok, 1.0 = her yanıt değerlendirilir
JUDGE_SAMPLE_RATE=0.2

# ─── Cost-Aware Model Routing (v5.0) ──────────────────────────────────────────
# true: Sorgu karmaşıklığı + günlük bütçeye göre lokal/bulut model otomatik seçilir
ENABLE_COST_ROUTING=false
# 0.0–1.0: Bu eşiğin altındaki sorgular lokal modele yönlendirilir
COST_ROUTING_COMPLEXITY_THRESHOLD=0.55
# Basit sorgular için kullanılacak lokal sağlayıcı
COST_ROUTING_LOCAL_PROVIDER=ollama
# Lokal model (boşsa CODING_MODEL/TEXT_MODEL kullanılır)
COST_ROUTING_LOCAL_MODEL=
# Karmaşık sorgular için kullanılacak bulut sağlayıcı (boşsa varsayılan sağlayıcı)
COST_ROUTING_CLOUD_PROVIDER=
# Bulut model (boşsa sağlayıcının varsayılan modeli kullanılır)
COST_ROUTING_CLOUD_MODEL=
# Günlük bulut harcaması bu USD değerini geçerse tüm sorgular lokal modele yönlenir
COST_ROUTING_DAILY_BUDGET_USD=1.0

# ─── Entity/Persona Memory (v5.0) ─────────────────────────────────────────────
# true: Kullanıcının kodlama stili ve tercihleri DB'de kalıcı olarak saklanır
ENABLE_ENTITY_MEMORY=true
# Güncellenmemiş persona kayıtları bu kadar günden sonra silinir (0 = sonsuz)
ENTITY_MEMORY_TTL_DAYS=90
# Kullanıcı başına maksimum persona anahtarı sayısı (aşılırsa en eski silinir)
ENTITY_MEMORY_MAX_PER_USER=100

# ─── Active Learning + LoRA/QLoRA Fine-tuning (v6.0) ──────────────────────────
# true: Kullanıcı geri bildirimleri (thumbs-up/down) saklanır ve dataset üretilir
ENABLE_ACTIVE_LEARNING=true
# Minimum geri bildirim puanı — bu değer ve üzeri fine-tuning dataseti'ne dahil edilir
AL_MIN_RATING_FOR_TRAIN=1
# true: PEFT/LoRA fine-tuning döngüsü aktif (peft + transformers gerektirir)
ENABLE_LORA_TRAINING=false
# HuggingFace model ID — LoRA eğitimi için temel model (örn. meta-llama/Llama-3.2-1B)
LORA_BASE_MODEL=
# LoRA adaptör boyutu (rank) — düşük değer: hızlı/hafif, yüksek değer: güçlü adaptasyon
LORA_RANK=8
LORA_ALPHA=16
LORA_DROPOUT=0.05
# Eğitim döngüsü sayısı
LORA_EPOCHS=3
LORA_BATCH_SIZE=4
# true: QLoRA (4-bit nicemleme, bitsandbytes gerektirir)
LORA_USE_4BIT=true
# LoRA adaptör çıktı dizini
LORA_OUTPUT_DIR=data/lora_adapters
# true: Judge + Active Learning sinyallerinden sürekli öğrenme bundle'ı üretir
ENABLE_CONTINUOUS_LEARNING=false
# LoRA/QLoRA eğitimi tetiklemek için gereken minimum SFT örnek sayısı
CONTINUOUS_LEARNING_MIN_SFT_EXAMPLES=20
# DPO/RLHF tercih dataseti export etmek için gereken minimum pair sayısı
CONTINUOUS_LEARNING_MIN_PREFERENCE_EXAMPLES=10
# Tek döngüde işlenecek maksimum bekleyen sinyal sayısı
CONTINUOUS_LEARNING_MAX_PENDING_SIGNALS=5000
# Arka plan döngüleri arasındaki minimum bekleme süresi (saniye)
CONTINUOUS_LEARNING_COOLDOWN_SECONDS=3600
# Dataset bundle + manifest çıkış dizini
CONTINUOUS_LEARNING_OUTPUT_DIR=data/continuous_learning
# SFT export formatı (jsonl, alpaca, sharegpt)
CONTINUOUS_LEARNING_SFT_FORMAT=alpaca

# ─── Multimodal Vision — UI Mockup → Frontend (v6.0) ─────────────────────────
# true: Görsel (PNG/JPEG) yükleyerek frontend kodu üretme aktif
ENABLE_VISION=true
# Kabul edilecek maksimum görsel boyutu (byte) — varsayılan 10 MB
VISION_MAX_IMAGE_BYTES=10485760
# true: Ses/video multimodal işleme hattı aktif
ENABLE_MULTIMODAL=true
# Maksimum medya boyutu (byte)
MULTIMODAL_MAX_FILE_BYTES=52428800
# Speech-to-text sağlayıcısı
VOICE_STT_PROVIDER=whisper
# Text-to-speech sağlayıcısı (auto, pyttsx3, mock)
VOICE_TTS_PROVIDER=auto
# İsteğe bağlı TTS ses adı/id'si
VOICE_TTS_VOICE=
# TTS sentezine gönderilecek minimum segment uzunluğu
VOICE_TTS_SEGMENT_CHARS=48
# Whisper model etiketi
WHISPER_MODEL=base
# Voice websocket buffer üst sınırı
VOICE_WS_MAX_BYTES=10485760

# ─── Slack Entegrasyonu (v6.0) ────────────────────────────────────────────────
# Slack Bot OAuth Token (xoxb-...) — slack-sdk kuruluysa tam API erişimi
SLACK_TOKEN=
# Incoming Webhook URL — token yoksa veya basit bildirim için kullanılır
SLACK_WEBHOOK_URL=
# Varsayılan hedef kanal (örn. #genel veya kanal ID'si)
SLACK_DEFAULT_CHANNEL=

# ─── Jira Entegrasyonu (v6.0) ─────────────────────────────────────────────────
# Atlassian Cloud URL (örn. https://sirket.atlassian.net)
JIRA_URL=
# API token — Atlassian hesap ayarlarından üretin
JIRA_TOKEN=
# Atlassian hesap e-postası (Cloud kimlik doğrulama için zorunlu)
JIRA_EMAIL=
# Varsayılan proje anahtarı (örn. PROJ)
JIRA_DEFAULT_PROJECT=

# ─── Microsoft Teams Entegrasyonu (v6.0) ──────────────────────────────────────
# Incoming Webhook URL — Teams kanalı > Bağlayıcılar > Incoming Webhook
TEAMS_WEBHOOK_URL=