# ─────────────────────────────────────────────
# Sidar Project — Çevre Değişkenleri Örneği
# Bu dosyayı .env olarak kopyalayın ve doldurun:
#   cp .env.example .env
#
# Bu şablon platformdan bağımsız güvenli başlangıç değerleri içerir.
# Donanımınıza göre (özellikle GPU ve timeout değerleri) özelleştirin.
# ─────────────────────────────────────────────

# ─── AI Sağlayıcısı ──────────────────────────
# "ollama" (yerel), "gemini" (bulut), "openai" (bulut) veya "anthropic" (bulut)
AI_PROVIDER=ollama

# ─── Ollama ──────────────────────────────────
# Eğer Sidar'ı Docker içinde, Ollama'yı ana makinede çalıştırıyorsanız URL:
# Windows/Mac Docker için: http://host.docker.internal:11434/api
# Linux için (host IP'si): http://172.17.0.1:11434/api
OLLAMA_URL=http://localhost:11434/api

# Ollama API zaman aşımı (saniye)
# Çoklu ajan sisteminde (model yükleme süreleri ve RAG bağlam okumaları için) 
# en az 120-300 saniye önerilir.
OLLAMA_TIMEOUT=180

# Kodlama ve teknik analiz görevleri için kullanılacak model
# Düşük VRAM'iniz (8GB altı) varsa qwen2.5-coder:3b kullanabilirsiniz.
CODING_MODEL=qwen2.5-coder:3b

# Genel iletişim, analiz ve supervisor işlemleri için kullanılacak model
# Alternatifler: llama3.1:8b veya qwen2.5:7b
TEXT_MODEL=llama3.1:8b

# ─── Google Gemini (opsiyonel) ────────────────
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ─── OpenAI (opsiyonel) ──────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT=60

# ─── Anthropic Claude (opsiyonel) ─────────────
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest
ANTHROPIC_TIMEOUT=60

# ─── Erişim Seviyesi (OpenClaw) ───────────────
# restricted : Yalnızca okuma ve denetim
# sandbox    : Okuma + /temp dizinine yazma (Varsayılan güvenli mod)
# full       : Tam erişim — Ajanların proje dosyalarını doğrudan düzenleyebilmesi
#              için gereklidir. Sadece Docker gibi konteyner izolasyonu 
#              aktifken kullanılması önerilir.
ACCESS_LEVEL=sandbox

# ─── Kimlik Doğrulama ─────────────────────────
# Web UI / API erişim anahtarı.
# Boş bırakılırsa auth katmanı devre dışı kalabilir; özellikle çok kullanıcılı 
# (multi-user) oturum yapılarında sistemi tamamen savunmasız bırakır.
# Güçlü bir anahtar üretmek için terminalde şu komutu çalıştırabilirsiniz:
# python -c "import secrets; print(secrets.token_urlsafe(32))"
#
# Not: install_sidar.sh scripti bu alan boşsa rastgele bir anahtar üretmeyi dener.
API_KEY=

# ─── Proaktif Otonomi ve Cron ─────────────────
# Otonomi webhook/cron tetikleyicileri için koruma (boş bırakılırsa devre dışı kalır)
# Güçlü bir secret üretmek için: python -c "import secrets; print(secrets.token_hex(32))"
AUTONOMY_WEBHOOK_SECRET=

# Proaktif cron tetikleyicisinin varsayılan promptu
# Sistemin kendi kendine iş bulması ve iyileştirme yapması için yönlendirme
AUTONOMOUS_CRON_PROMPT=Sistemdeki bekleyen otonom iş fırsatlarını değerlendir ve gerekli aksiyon planını çıkar.

# ─── Gece Bakımı (Nightly Maintenance) ─────────
# Gece döngüsü: hafıza konsolidasyonu, eski oturumların sıkıştırılması ve vektör optimizasyonu
ENABLE_NIGHTLY_MEMORY_PRUNING=false

# Bakım döngüsünün çalışma sıklığı (varsayılan: 86400 saniye = 24 saat)
NIGHTLY_MEMORY_INTERVAL_SECONDS=86400

# Sistemin bakıma girmesi için gereken eylemsizlik süresi (varsayılan: 1800 saniye = 30 dakika)
NIGHTLY_MEMORY_IDLE_SECONDS=1800

# Sıkıştırılmadan olduğu gibi korunacak en yeni oturum sayısı
NIGHTLY_MEMORY_KEEP_RECENT_SESSIONS=2

# Bir oturumun sıkıştırmaya dahil edilmesi için minimum mesaj sayısı
NIGHTLY_MEMORY_SESSION_MIN_MESSAGES=12

# RAG optimizasyonunda (nightly-digest) dokunulmayacak en güncel dosya sayısı
NIGHTLY_MEMORY_RAG_KEEP_RECENT_DOCS=2

# ─── Çoklu Ajan Federasyonu (Swarm) ────────────
# Harici ajanların (CrewAI, AutoGen vb.) Sidar ile konuşabilmesi için paylaşılan imza anahtarı
SWARM_FEDERATION_SHARED_SECRET=

# ─── GitHub (opsiyonel) ───────────────────────
# Ajanların PR oluşturması, kod incelemesi ve Issue okuması için gereklidir.
# github.com/settings/tokens adresinden "repo" erişimli bir token üretip buraya yazın.
GITHUB_TOKEN=

# İşlem yapılacak varsayılan depo (Örn: kullanici/depo-adi)
GITHUB_REPO=niluferbagevi-gif/Sidar

# GitHub webhook imza doğrulaması için secret
# Proje ayarlarından (Webhooks) üreteceğiniz imza secret değerini buraya yazın.
GITHUB_WEBHOOK_SECRET=

# ─── Donanım & GPU ───────────────────────────
# true = PyTorch CUDA varsa GPU kullan (Kurulum script'i GPU tespit ederse otomatik true yapar)
USE_GPU=false

# true = GPU zorunlu ön koşul; GPU yoksa uygulama kritik doğrulamadan geçmez ve başlar başlamaz durur.
REQUIRE_GPU=false

# Birden fazla GPU varsa hangi cihaz kullanılsın (0-indexed)
GPU_DEVICE=0

# Çoklu GPU dağıtık mod (çoğu standart/tek GPU kurulumunda false bırakın)
MULTI_GPU=false

# ─── VRAM Yönetimi (Kritik) ───
# NOT: Aşağıdaki LLM ve RAG fraksiyonlarının toplamı 1.0 (veya daha büyük) OLMAMALIDIR.
# İkisinin toplamı, karta ayrılacak maksimum belleği belirler. Toplamın 0.90 - 0.95 arası olması önerilir.

# Genel/Eski VRAM fraksiyonu (Aşağıdaki iki ayar boşsa bu değer kullanılır)
GPU_MEMORY_FRACTION=0.8

# LLM çalışma belleği (VRAM) için ayrılan oran (0.1 – 0.9)
LLM_GPU_MEMORY_FRACTION=0.6

# RAG / Vektör Embedding iş akışı için ayrılan oran (0.1 – 0.5)
RAG_GPU_MEMORY_FRACTION=0.3

# FP16 mixed precision → ChromaDB/pgvector embedding'de VRAM tasarrufu sağlar.
# RTX 2000, 3000, 4000 serisi gibi yeni nesil GPU'larda 'true' yapmanız performansı artırır.
GPU_MIXED_PRECISION=false

# ─── HuggingFace ─────────────────────────────
# Model ilk indirildikten sonra HF_HUB_OFFLINE=1 yapın:
# → Her açılışta internet kontrolü yapmaz, cache'den hızlıca yükler (~1 dk tasarruf)
# İlk kurulumda veya model güncellemek istediğinizde 0 yapın.
HF_TOKEN=
HF_HUB_OFFLINE=0

# ─── Uygulama ve Hafıza ──────────────────────
# Sistem kaç mesaj turundan sonra eski konuşmaları özetleyip vektör arşive kaldıracak?
MAX_MEMORY_TURNS=20

# Özetleme yapıldıktan sonra bağlamda bozulmadan bırakılacak en yeni mesaj turu sayısı
MEMORY_SUMMARY_KEEP_LAST=4

RESPONSE_LANGUAGE=tr
DEBUG_MODE=false

# Ortam profili (development / staging / production)
# Lokal varsayılan: development. Üretim (sunucu) ortamında 'production' yapın.
SIDAR_ENV=development

# ─── Reviewer Ajanı Test Otomasyonu ──────────
# ReviewerAgent doğrulama aşamasında çalıştırılacak test komutu (Sandbox içinde çalışır)
# Projenize göre uyarlayın: pytest, npm test, veya bash run_tests.sh
REVIEWER_TEST_COMMAND=bash run_tests.sh

# ─── Browser Otomasyonu ──────────────────────
# Otonom web gezintisi ve DOM okuma için: auto, playwright veya selenium
BROWSER_PROVIDER=auto

# ─── Dil Sunucuları (LSP) Analiz Araçları ────
# NOT: Aşağıdaki araçların sunucuda (veya Docker içinde) kurulu olduğundan emin olun.
# Kurulum için: npm install -g pyright typescript typescript-language-server

# Python LSP sunucusu komutu (örn. pyright-langserver veya pylsp)
PYTHON_LSP_SERVER=pyright-langserver --stdio

# TypeScript/JavaScript LSP sunucusu komutu
TYPESCRIPT_LSP_SERVER=typescript-language-server --stdio

# ─── Loglama ve Gözlemlenebilirlik ───────────
# Çalışma seviyesi: INFO, DEBUG, WARNING, ERROR, CRITICAL
# NOT: Ajanların ürettiği ham promptları, API yanıtlarını ve detaylı
# düşünme (reasoning) adımlarını görmek istiyorsanız 'DEBUG' yapın.
LOG_LEVEL=INFO

# Log dosyası yolu (proje köküne göre)
# Docker kullanıyorsanız 'logs/' dizinini kalıcı bir volume olarak bağlamayı unutmayın.
LOG_FILE=logs/sidar_system.log

# Tek log dosyası maksimum boyutu (byte) — varsayılan 10485760 (10 MB)
LOG_MAX_BYTES=10485760

# Tutulacak geçmiş log dosyası sayısı (Disk şişmesini engeller)
# 5 yedek x 10 MB = Toplam ~50 MB log saklanır.
LOG_BACKUP_COUNT=5

# ─── ReAct (Düşünme ve Eylem) Döngüsü ────────
# Bir ajanın tek bir görev için atabileceği maksimum adım sayısı.
# Ajan bu limite ulaşıyorsa muhtemelen çözümsüz bir döngüye (loop) girmiştir.
MAX_REACT_STEPS=10

# Tüm bir ReAct döngüsünün (baştan sona) tamamlanması için maksimum süre (saniye).
# NOT: 60 saniye kodlama/analiz görevleri için yetersiz kalır. Yerel LLM'ler (Ollama)
# kullanıyorsanız modelin düşünme ve araç çalıştırma sürelerini kapsayacak 
# en az 300-600 saniye arası bir değer önerilir.
REACT_TIMEOUT=300

# Alt ajanlara devredilen (delegasyon) görevlerde maksimum adım sayısı.
# Ana ajanın kaynaklarını tüketmemesi için düşük tutulmalıdır.
SUBTASK_MAX_STEPS=5

# CLI ve Web UI üzerindeki kısa/otomatik komutlarda (örn: .status, .health) 
# sistemin kilitlenmesini önleyen maksimum bekleme süresi (saniye).
AUTO_HANDLE_TIMEOUT=12

# ─── LLM Retry Ayarları ───────────────────────
# LLM sağlayıcı çağrılarında maksimum yeniden deneme sayısı
LLM_MAX_RETRIES=2
# Exponential backoff başlangıç gecikmesi (saniye)
LLM_RETRY_BASE_DELAY=0.4
# Exponential backoff için üst gecikme sınırı (saniye)
LLM_RETRY_MAX_DELAY=4.0

# ─── LiteLLM Gateway (opsiyonel) ────────────
# AI_PROVIDER=litellm yapıldığında tüm LLM trafiği bu gateway üzerinden geçer.
# LiteLLM proxy belgeleri: https://docs.litellm.ai/docs/proxy_server

# Eğer LiteLLM ana makinede, Sidar Docker'da çalışıyorsa (Windows/Mac için): 
# http://host.docker.internal:4000
LITELLM_GATEWAY_URL=http://localhost:4000

# LiteLLM proxy veya OpenRouter API anahtarını buraya yazın
LITELLM_API_KEY=

# Birincil model: LiteLLM proxy'de tanımlı olan veya doğrudan OpenRouter model adı
LITELLM_MODEL=gpt-4o-mini

# Fallback (Yedek) Modeller: Virgülle ayrılmış liste. 
# Birincil model (gpt-4o-mini) kota aşımı veya kesinti yaşarsa sırayla bunlar denenir.
LITELLM_FALLBACK_MODELS=claude-3-haiku-20240307,gemini-2.5-flash

# API zaman aşımı (saniye). Karmaşık ajan döngüleri için 60 yeterli olabilir,
# ancak ağır kodlama görevlerinde 120'ye çıkarmanız önerilir.
LITELLM_TIMEOUT=60

# ─── Anlamsal Önbellekleme (Semantic Cache, v4.0) ───
# Tekrar eden veya anlamsal olarak çok benzer soruların Redis üzerinden 
# LLM'e gidilmeden yanıtlanmasını sağlar. (Token maliyetini ve yanıt süresini düşürür)
# NOT: 'true' yapmadan önce sistemde Redis'in çalıştığından emin olun.
ENABLE_SEMANTIC_CACHE=false

# Kosinüs benzerlik eşiği (0.0 - 1.0)
# 0.95 çok güvenli/katı bir değerdir, ancak önbelleğe isabet (HIT) oranını düşürebilir.
# Yanlış eşleşmeleri (False Positive) önlemek için 0.90'ın altına inilmesi önerilmez.
SEMANTIC_CACHE_THRESHOLD=0.95

# Önbellekteki bir yanıtın geçerlilik süresi (saniye) — varsayılan: 3600 (1 saat)
SEMANTIC_CACHE_TTL=3600

# Önbellekte tutulacak maksimum soru-cevap öğesi sayısı.
# Limit aşıldığında en eski/en az kullanılan öğeler silinir (LRU).
# Üretim ortamında (RAM durumuna göre) 5000-10000 değerlerine çıkarabilirsiniz.
SEMANTIC_CACHE_MAX_ITEMS=500

# ─── Veritabanı ve RAG Arka Ucu (v4.0) ──────
# RAG arka ucu olarak ChromaDB yerine PostgreSQL pgvector kullan
RAG_VECTOR_BACKEND=pgvector

# Uygulama genel veritabanı bağlantısı.
# Varsayılan (Geliştirme/Yerel): postgresql+asyncpg://sidar:sidar@localhost:5432/sidar
# SQLite (opsiyonel/legacy): sqlite+aiosqlite:///data/sidar.db
# Veritabanı adı Sidar için `sidar` olmalıdır (eski `lotus` adını kullanmayın).
DATABASE_URL=postgresql+asyncpg://sidar:sidar@localhost:5432/sidar

# Şema migrasyon versiyonlarını izleyen tablo adı
DB_SCHEMA_VERSION_TABLE=schema_versions

# ChromaDB anonim telemetri gönderimini tamamen kapatır. 
# Kurumsal gizlilik ve offline ortamlardaki PostHog bağlantı hatalarını önlemek için 'false' kalmalıdır.
ANONYMIZED_TELEMETRY=false

# ─── pgvector Ayarları (Sadece pgvector seçiliyse geçerlidir) ───
PGVECTOR_TABLE=rag_embeddings

# Vektör boyutu (Dimension).
# KRİTİK UYARI: Bu değer, kullanılan embedding modelinin çıktı boyutuyla BİREBİR eşleşmelidir!
# - all-MiniLM-L6-v2       -> 384
# - nomic-embed-text       -> 768
# - text-embedding-3-small -> 1536
PGVECTOR_EMBEDDING_DIM=384

# Metinleri vektöre dönüştürecek modelin adı
PGVECTOR_EMBEDDING_MODEL=all-MiniLM-L6-v2

# ─── Dağıtık Ajan Event Bus (v4.0) ──────────
# Ajanların birbirleriyle (veya harici sistemlerle) olay tabanlı haberleşmesi içindir.
# Local geliştirmede Redis yoksa otomatik olarak bellek içi (in-memory) kuyruğa döner.
# KRİTİK UYARI: Üretim (Production) ve çoklu sunucu ortamında Redis KESİNLİKLE aktif olmalıdır.

# Event Bus kanal ve grup adları
# Aynı Redis'i kullanan farklı ortamlarınız (dev/prod) varsa, çakışmayı önlemek için 
# isimleri değiştirin (Örn: sidar_prod:agent_events)
SIDAR_EVENT_BUS_CHANNEL=sidar:agent_events
SIDAR_EVENT_BUS_GROUP=sidar:agent_events:cg

# DLQ (Dead Letter Queue) - İşlenemeyen/Başarısız olayların atılacağı kuyruk
SIDAR_EVENT_BUS_DLQ_CHANNEL=sidar:agent_events:dlq

# DLQ Maksimum Uzunluğu
# Başarısız mesajların Redis RAM'ini tüketmesini engeller (varsayılan: 1000)
SIDAR_EVENT_BUS_DLQ_MAXLEN=1000

# ─── Gözlemlenebilirlik (OpenTelemetry / Jaeger) ─────
# Ajanların düşünme sürelerini, API çağrılarını ve darboğazları izlemek içindir.
# NOT: 'true' yapmadan önce OTel bağımlılıklarının kurulu olduğundan emin olun.
ENABLE_TRACING=false

# OTel verilerinin gönderileceği sunucu (gRPC portu).
# Docker Compose kullanıyorsanız: http://jaeger:4317
# Doğrudan makinede yerel çalıştırıyorsanız: http://localhost:4317
OTEL_EXPORTER_ENDPOINT=http://jaeger:4317

# OTel servis adı (Jaeger/Zipkin arayüzünde uygulamanın görüneceği isim)
OTEL_SERVICE_NAME=sidar

# API isteklerini (FastAPI) ve dış çağrıları (HTTPX - LLM istekleri) otomatik izle
# (Sadece ENABLE_TRACING=true ise devreye girer)
OTEL_INSTRUMENT_FASTAPI=true
OTEL_INSTRUMENT_HTTPX=true

# ─── Redis (Kalıcı Rate Limiting & Önbellek) ───────────
# Redis bağlantı dizesi.
# Yerel geliştirme (host makineden erişim) için varsayılan: redis://localhost:6379/0
# Docker container içi ağdan erişim için: redis://redis:6379/0
# Parolalı kullanım örneği: redis://:sifre@localhost:6379/0
REDIS_URL=redis://localhost:6379/0

# Güvenilir ters proxy IP'leri (virgülle ayrılmış). 
# Boşsa X-Forwarded-For/X-Real-IP başlıkları KABUL EDİLMEZ ve 
# Rate Limiting için direkt bağlantının IP'si kullanılır (Güvenli varsayılan).
#
# Eğer uygulama Nginx/Traefik veya Cloudflare arkasındaysa proxy IP'sini girin.
# Örnek: TRUSTED_PROXIES=10.0.0.1,10.0.0.2
# NOT: Sadece yerel Docker ağında test yapıyorsanız (veya proxy'nize tam güveniyorsanız)
# hepsine izin vermek için TRUSTED_PROXIES=* yapabilirsiniz.
TRUSTED_PROXIES=

# ─── API Hız Sınırları (Rate Limiting) ───────
# NOT: Sınırlar varsayılan olarak IP adresi başına hesaplanır. 
# 60 saniyelik (1 dakika) penceredeki maksimum istek limitleri:
RATE_LIMIT_WINDOW=60

# Kullanıcı sohbet istekleri (Harici entegrasyonlar/botlar kullanıyorsanız artırın)
RATE_LIMIT_CHAT=20

# Veri değiştirme (POST/PUT/DELETE) işlemleri
RATE_LIMIT_MUTATIONS=60

# Standart okuma (GET) işlemleri
RATE_LIMIT_GET_IO=30

# ─── RAG ve Dosya Yönetimi ───────────────────
# RAG dosya yükleme maksimum boyut sınırı (byte cinsinden)
# Varsayılan: 52428800 (50 MB). 
# UYARI: Bu boyut MP4/WebM gibi medya dosyaları için idealdir. Ancak 50 MB'lık devasa 
# saf metin (PDF/TXT) dosyalarının vektörel işlenmesi (embedding) çok uzun sürebilir.
MAX_RAG_UPLOAD_BYTES=52428800

# ─── Gözlemlenebilirlik Güvenliği ────────────
# /metrics, /metrics/llm, /api/budget uçları için statik Bearer token.
# Boş bırakılırsa bu uçlara dışarıdan / yetkisiz erişim tamamen kapatılır.
#
# Docker ile Grafana/Prometheus kullanıyorsanız, buraya ürettiğiniz token'ı 
# prometheus.yml dosyasındaki 'bearer_token' alanına da eklemelisiniz.
# Güçlü bir token için: python -c "import secrets; print(secrets.token_urlsafe(32))"
METRICS_TOKEN=

# ─── Web Arama (Ajanların İnternet Erişimi) ───
# Seçenekler: auto, duckduckgo, tavily veya google
# 'auto' seçildiğinde sistem uygun API anahtarını arar, bulamazsa 
# ücretsiz duckduckgo üzerinden çalışmaya devam eder.
SEARCH_ENGINE=auto

# Tavily API Anahtarı (Yapay zeka için optimize edilmiş arama motoru - Önerilen)
# app.tavily.com üzerinden ücretsiz API key oluşturup buraya yapıştırın.
TAVILY_API_KEY=

# Google Search API Anahtarları
# Google Cloud Console'da Custom Search JSON API key oluşturun.
GOOGLE_SEARCH_API_KEY=
# programmablesearchengine.google.com üzerinden Search Engine ID (cx) değerini alın.
GOOGLE_SEARCH_CX=

# ─── Arama ve Kazıma (Scraping) Limitleri ───
# DuckDuckGo arama sonucu sayısı (1-10 arası önerilir)
WEB_SEARCH_MAX_RESULTS=5

# URL içerik çekme zaman aşımı (saniye)
WEB_FETCH_TIMEOUT=15

# LLM Context Window (Bağlam Penceresi) Koruması (KRİTİK)
# Çekilen web sayfasının maksimum karakter sınırı. 12.000 karakter ~3000 token yapar.
# Bu değer, modelin hafızasının gereksiz web verisiyle (HTML, uzun metinler) 
# dolmasını ve Out-Of-Memory (OOM) hatalarını engeller.
WEB_FETCH_MAX_CHARS=12000

# Yeni adlandırma: web_scrape önceliği
# (Geriye dönük uyumluluk için ikisini de aynı tutun)
WEB_SCRAPE_MAX_CHARS=12000

# ─── Paket Bilgi ve Versiyon Kontrolü ────────
# Ajanların kod yazarken uydurma (halüsinasyon) kütüphaneler kullanmasını önlemek
# için PyPI, npm ve GitHub üzerinden gerçek paket verilerini çeken modülün ayarları.

# Dış API'lere (PyPI/npm/GitHub) yapılan istekler için zaman aşımı (saniye).
# 12 saniye idealdir; sunucular yavaşsa ajan kilitlenmek yerine elindeki veriyle devam eder.
PACKAGE_INFO_TIMEOUT=12

# Paket sorgu sonuçlarının önbellekte (cache) tutulma süresi (saniye).
# Varsayılan: 1800 (30 dakika).
# LLM ve dış API hız sınırlarını (Rate Limit) korumak için bu değeri çok düşürmeyin.
PACKAGE_INFO_CACHE_TTL=1800

# ─── RAG — Belge Deposu ve Vektör Hafıza ──────
# Kullanıcıların yüklediği belgelerin ve ChromaDB veritabanının saklanacağı dizin.
# UYARI: Docker kullanıyorsanız 'data/' dizinini mutlaka kalıcı bir volume olarak bağlayın,
# aksi takdirde konteyner silindiğinde tüm belgeleriniz ve vektör hafızanız kaybolur.
RAG_DIR=data/rag

# LLM'e gönderilecek (soruyla en alakalı) maksimum belge parçası sayısı.
# Karmaşık analizlerde ajanın daha fazla bağlam görebilmesi için 4 veya 5 önerilir.
RAG_TOP_K=4

# ─── Metin Parçalama (Chunking) Stratejisi ───
# Her bir belge parçasının boyutu (karakter). 1000 karakter ~250 token yapar.
# all-MiniLM-L6-v2 gibi modellerle tam uyumlu çalışması için idealdir.
RAG_CHUNK_SIZE=1000

# Parçalar arası örtüşme (overlap) miktarı.
# Cümlelerin ortadan kesilip anlam kaybı yaşanmasını önler (Standart: %20).
RAG_CHUNK_OVERLAP=200

# Bağlam penceresini (Context Window) koruma eşiği (karakter).
# Bu sınırı (~20.000 karakter / ~5000 token) geçen devasa dosyalar 
# doğrudan LLM'e verilmek yerine zorunlu olarak RAG üzerinden parçalanarak okunur.
RAG_FILE_THRESHOLD=20000

# ─── Konuşma Geçmişi Şifrelemesi (DLP/Güvenlik) ──────────
# Ajanlarla yapılan sohbetlerin ve varlık (entity) hafızasının veritabanında 
# şifreli (AES128/Fernet) olarak tutulmasını sağlar. (RAG vektörlerini etkilemez).
# Boş bırakılırsa şifreleme devre dışı kalır (Geliştirme için önerilen varsayılan).

# KRİTİK UYARI: Şifrelemeyi açarsanız bu anahtarı ASLA kaybetmeyin veya değiştirmeyin! 
# Aksi takdirde veritabanındaki eski konuşmalarınıza bir daha erişilemez ve çöpe döner.
#
# Kurumsal ve hassas veriler (Production) için güçlü bir Fernet anahtarı üretin:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
#
# Üretilen anahtarı buraya yapıştırın (44 karakter, = ile biter):
MEMORY_ENCRYPTION_KEY=

# ─── Web Arayüzü ve Ağ ───────────────────────
# Dinlenecek adres.
# 0.0.0.0   : Tüm ağa açar. Docker veya Sunucu (Production) ortamı için zorunludur.
# localhost : Yalnızca kendi bilgisayarınızdan erişilir (Güvenli yerel geliştirme).
#
# KRİTİK UYARI: Eğer API_KEY boşsa ve 0.0.0.0 kullanıyorsanız, aynı ağdaki 
# (örn. ortak Wi-Fi) herkes Sidar arayüzüne şifresiz erişebilir!
WEB_HOST=0.0.0.0

# Web arayüzü port numarası (AI uygulamaları için yaygın standart)
# NOT: Eğer bilgisayarınızda Stable Diffusion (Automatic1111) veya ComfyUI 
# çalışıyorsa port çakışması yaşayabilirsiniz. Bu durumda 7862 gibi bir değere alın.
WEB_PORT=7860

# GPU tabanlı işlemler için ayrılmış ikincil servis portu 
# (docker-compose.yml içindeki sidar-web-gpu servisi ile eşleşmelidir)
WEB_GPU_PORT=7861

# ─── JWT Kimlik Doğrulama (Güvenlik Katmanı) ───
# ÜRETİM (Production) ORTAMINDA ZORUNLU: Güçlü ve rastgele bir değer kullanın.
# Terminalde güvenli bir anahtar oluşturmak için şu komutu çalıştırabilirsiniz:
# python -c "import secrets; print(secrets.token_urlsafe(64))"
#
# UYARI: Bu alan boş bırakılırsa sunucu başlangıcında CRITICAL uyarısı verir.
JWT_SECRET_KEY=

# Şifreleme algoritması (Varsayılan ve önerilen: HS256)
# NOT: RS256 kullanmak isterseniz, public/private anahtar dosyalarına (.pem) 
# ihtiyacınız olacağını unutmayın.
JWT_ALGORITHM=HS256

# Token geçerlilik süresi (Gün) — Varsayılan: 7
# Kullanıcı deneyimi için 7 gün idealdir ancak dışa açık, yüksek güvenlik 
# gerektiren sunucularda (çalınma riskine karşı) 1 veya 3 güne düşürmeniz önerilir.
JWT_TTL_DAYS=7

# ─── Gözlemlenebilirlik (UI Yönlendirmeleri) ─
# Admin panelindeki "Grafana'yı Aç" butonu bu URL'yi kullanır.
#
# KRİTİK NOT: Bu adres arka uç (backend) iletişimi için değil, kullanıcının
# tarayıcısında (Frontend) açılacak link için kullanılır. Bu yüzden Docker
# iç ağ servis adresi (http://grafana:3000) KULLANILMAMALIDIR. 
#
# Her zaman kullanıcının dışarıdan erişebileceği (Public) adresi yazın.
# Yerel testler (Docker dahil) için: http://localhost:3000
# Üretim (Sunucu) ortamı için örnek: https://grafana.sirketiniz.com
GRAFANA_URL=http://localhost:3000

# ─── Docker REPL Sandbox (Güvenli Kod Çalıştırma) ─────────
# Ajanların yazdığı kodları ana sistemden izole bir şekilde çalıştırmasını sağlar.

# CodeManager sandbox imajı. (Varsayılan: python:3.11-slim)
# NOT: Alpine yerine 'slim' kullanılması Pandas/Numpy gibi C tabanlı AI 
# kütüphanelerinin çok daha hızlı ve hatasız kurulmasını sağlar.
DOCKER_PYTHON_IMAGE=python:3.11-slim

# Sandbox maksimum çalışma süresi (saniye) — Sonsuz döngü koruması.
# UYARI: Eğer ajanların pip install ile paket kurmasına izin veriyorsanız,
# indirme sürelerini hesaba katarak bu değeri 30 veya 60 yapmanız önerilir.
DOCKER_EXEC_TIMEOUT=30

# Docker Zorunlu Modu (Kritik Güvenlik Ayarı)
# false: Docker bulunamazsa kodlar GÜVENSİZ bir şekilde ana makinede (subprocess) çalışır. (Sadece yerel test için)
# true : Docker yoksa kod çalıştırılmaz ve sistem güvenli bir şekilde işlemi reddeder.
# ÜRETİM (PRODUCTION) SUNUCUSUNDA KESİNLİKLE 'true' YAPILMALIDIR.
DOCKER_REQUIRED=false

# ─── Gelişmiş İzolasyon ve Micro-VM ──────────
# Üst düzey kurumsal güvenlik için gVisor (runsc) veya Kata Containers kullanılabilir.
DOCKER_RUNTIME=
DOCKER_ALLOWED_RUNTIMES=,runc,runsc,kata-runtime
DOCKER_MICROVM_MODE=off

# ─── Kaynak Sınırları ─────────────────────────
# Docker sandbox bellek limiti (config.py fallback: 256m)
# Veri bilimi kütüphaneleri (Pandas vb.) belleğe yüklendiğinde fazla RAM tüketir.
# OOMKilled (Bellek Aşımı) çöküşlerini önlemek için minimum 512m veya 1g önerilir.
DOCKER_MEM_LIMIT=512m

# ─── Sandbox Kaynak Kotaları (Gelişmiş / Güvenlik) ───
# Aşağıdaki değerler config.py::SANDBOX_LIMITS içinde kullanılır.
# Ajanların ürettiği hatalı veya zararlı kodların ana makineyi kilitlemesini 
# (DDoS, Fork Bomb, OOM) engellemek için tasarlanmıştır.

# Sandbox maksimum bellek limiti. 
# Veri analizi (Pandas/Numpy) ve ağır işlemler için 512m veya 1g önerilir.
SANDBOX_MEMORY=512m

# Konteynerin kullanabileceği maksimum CPU çekirdeği sayısı.
# 0.5 çok güvenlidir ancak paket kurulumlarında (pip install) ajanı çok yavaşlatır.
# Çoğu genel senaryo için 1.0 idealdir.
SANDBOX_CPUS=1.0

# ─── Sandbox Ağ İzolasyonu (KRİTİK) ───────────
# 'none'   : Tamamen internetsiz/izole ortam. En güvenlisidir ancak ajan 
#            dış dünyadan veri çekemez ve pip paketleri kuramaz.
# 'bridge' : Standart internet erişimi. Ajanın araştırma yapması ve kütüphane 
#            indirmesi gerekiyorsa bunu kullanın.
SANDBOX_NETWORK=bridge

# Maksimum işlem (Process/Thread) limiti.
# Ajanın zararlı veya sonsuz döngülü bir "Fork Bomb" yazarak sunucuyu çökertmesini engeller.
# 64 son derece dengeli ve güvenli bir limittir.
SANDBOX_PIDS_LIMIT=64

# Gelişmiş mod maksimum çalışma süresi (saniye).
# İnternetten dosya indirme veya kütüphane derleme süreleri için 30-60 arası önerilir.
SANDBOX_TIMEOUT=30

# ─── DLP (Veri Kaybı Önleme / KVKK Uyumluluğu) (v4.1) ─────────
# Ajanların dışarıdaki API'lere (OpenAI, Anthropic vb.) veya dış servislere
# hassas verileri (Kredi Kartı, TCKN, E-posta vb.) göndermesini engeller.

# true: LLM API çağrılarından önce PII (Kişisel Veri) tespit eder ve maskeler (önerilir).
# UYARI: Eğer ajanların spesifik e-posta veya isimlerle çalışması gerekiyorsa 
# (örn. Müşteri Destek ajanı), maskeleme kurallarını config.py'den esnetmeniz gerekebilir.
DLP_ENABLED=true

# true: Maskeleme tespitleri WARNING seviyesinde loglanır.
# Güvenlik ve disk alanı için üretimde 'false' bırakın, ancak ajanların neden 
# eksik bilgiyle (maskelenmiş) yanıt verdiğini anlamak için geliştirme ortamında 'true' yapın.
DLP_LOG_DETECTIONS=false

# ─── HITL — Human-in-the-Loop (İnsan Onay Geçidi) (v4.1) ──────────
# Ajanların bağımsızlığını (otonomi) kısıtlayarak kritik noktalarda kontrolü ele almanızı sağlar.

# true: Dosya silme, dış API'lere yazma, PR oluşturma veya sunucu 
# komutları çalıştırma gibi yıkıcı/kalıcı işlemler insan onayına sunulur.
# UYARI: Tam otonomi için 'false' bırakabilirsiniz ancak üretim (Production) 
# ortamında ve projeyi ilk tanıma aşamasında 'true' yapılması şiddetle önerilir.
HITL_ENABLED=false

# Bekleyen bir işlemin onaylanması için tanınan maksimum süre (saniye).
# Bu süre aşılırsa ajan işlemi güvenlik gereği "Reddedildi" sayar.
# NOT: 120 saniye kod incelemek için genelde yetersiz kalır. 
# Kullanıcıyı strese sokmamak için 300 (5 dk) veya 600 (10 dk) önerilir.
HITL_TIMEOUT_SECONDS=300

# ─── LLM-as-a-Judge Kalite Değerlendirmesi (v4.1) ──────────
# Ajanların ürettiği RAG veya kodlama yanıtlarının başka bir LLM tarafından 
# asenkron (arka planda) değerlendirilerek skorlanmasını sağlar.

# true: Değerlendirme aktif olur. 
# UYARI: Bu özellik arka planda ekstra API çağrısı (maliyet) veya yerel 
# modellerde ekstra VRAM/CPU tüketimi yaratır. Geliştirme ortamında false önerilir.
JUDGE_ENABLED=false

# Değerlendirme sağlayıcısı (ollama, gemini, openai, anthropic, litellm)
# Yerel modellerle üretiyor, bulut ile denetliyorsanız 'openai' veya 'litellm' yapabilirsiniz.
JUDGE_PROVIDER=ollama

# Değerlendirme için kullanılacak spesifik model.
# Boş bırakılırsa ana sistemdeki TEXT_MODEL kullanılır. Ancak sağlıklı bir denetim 
# için "Hakim" modelin ana modelden daha yetenekli olması önerilir (Örn: gpt-4o).
JUDGE_MODEL=

# Örnekleme oranı (0.0 ile 1.0 arası)
# 0.2 = Yanıtların rastgele %20'si kalite denetimine sokulur (Maliyet/Performans dengesi).
# Her yanıtı değerlendirmek isterseniz 1.0 yapın.
JUDGE_SAMPLE_RATE=0.2

# ─── Cost-Aware Model Routing (Akıllı Maliyet Yönlendirme, v5.0) ──────────
# Sorgunun karmaşıklığına (complexity) ve günlük bütçenize göre istekleri 
# otonom olarak yerel (ücretsiz) ve bulut (ücretli) modeller arasında dağıtır.

# true: Yönlendirme aktif. 
# UYARI: Bunu 'true' yapmadan önce sistemde en az bir adet Bulut (Cloud) 
# sağlayıcısının API anahtarının (OpenAI, Anthropic vb.) girildiğinden emin olun!
ENABLE_COST_ROUTING=false

# Karmaşıklık Eşiği (0.0 ile 1.0 arası)
# 0.55: Dengeli bir değerdir. 
# Bu değeri DÜŞÜRMEK daha çok görevi yerel modele atar (Maliyet düşer).
# Bu değeri YÜKSELTMEK daha çok görevi buluta atar (Zeka ve maliyet artar).
COST_ROUTING_COMPLEXITY_THRESHOLD=0.55

# Basit sorgular için kullanılacak yerel (ücretsiz) sağlayıcı
COST_ROUTING_LOCAL_PROVIDER=ollama

# Yerel model (Boş bırakılırsa sistemdeki varsayılan TEXT_MODEL / CODING_MODEL kullanılır)
COST_ROUTING_LOCAL_MODEL=

# Karmaşık sorgular için kullanılacak bulut (ücretli) sağlayıcı
# (Boş bırakılırsa sistemin bulut sağlayıcısı varsayılanı kullanılır)
COST_ROUTING_CLOUD_PROVIDER=

# Bulut model (Boş bırakılırsa sağlayıcının varsayılan en zeki modeli kullanılır)
COST_ROUTING_CLOUD_MODEL=

# Günlük Güvenlik Bütçesi (USD cinsinden)
# Bulut harcaması bu değeri geçerse (fatura şokunu önlemek için) sistem 
# zorunlu olarak tamamen yerel modellere yönlenir.
# NOT: 1.0 USD çok güvenli bir başlangıçtır ancak çoklu ajan döngülerinde 
# hızlıca tükenebilir. Üretim ortamında (takım kullanımı) 5.0 - 10.0 önerilir.
COST_ROUTING_DAILY_BUDGET_USD=1.0

# ─── Entity/Persona Memory (Proaktif Çalışma Arkadaşı, v5.0) ───────────
# Ajanların sizin kodlama stilinizi, proje tercihlerinizi ve sık kullandığınız 
# araçları (framework, dil standartları) öğrenip veritabanında saklamasını sağlar.

# true: Kullanıcı alışkanlıkları kalıcı olarak izlenir ve sonraki sohbetlerde otomatik uygulanır.
ENABLE_ENTITY_MEMORY=true

# Güncellenmemiş persona kayıtlarının (alışkanlıkların) silinme süresi (Gün).
# Sunucu/SaaS ortamlarında disk tasarrufu için 90 gün idealdir.
# NOT: Kendi yerel bilgisayarınızda (Local) kullanıyorsanız, ajanın eski projelerdeki 
# tercihlerinizi unutmaması için bunu 0 (sonsuz) yapmanız şiddetle önerilir.
ENTITY_MEMORY_TTL_DAYS=90

# Kullanıcı başına aklında tutabileceği maksimum alışkanlık/bilgi sayısı (Örn: "snake_case sever").
# Limit aşıldığında en eski ve en az kullanılan bilgi silinir (LRU mantığı).
# Çok karmaşık ve uzun soluklu projelerde bu değeri 200 veya 500'e çıkarabilirsiniz.
ENTITY_MEMORY_MAX_PER_USER=100

# ─── Active Learning + LoRA/QLoRA Fine-tuning (Kendi Kendini Eğitme, v6.0) ───
# Kullanıcı geri bildirimlerini (thumbs-up/down) ve düzeltmeleri kullanarak 
# sistemin kendi modelini arka planda eğitmesini (Fine-Tuning) sağlar.

# true: Kullanıcı geri bildirimleri saklanır ve otomatik dataset üretilir.
ENABLE_ACTIVE_LEARNING=true

# Minimum geri bildirim puanı — Bu değer ve üzeri fine-tuning dataset'ine dahil edilir.
AL_MIN_RATING_FOR_TRAIN=1

# ─── Model Eğitimi (HuggingFace & LoRA Ayarları) ───
# true: PEFT/LoRA fine-tuning döngüsünü aktif eder. 
# KRİTİK UYARI: Model eğitmek, model çalıştırmaktan (inference) çok daha fazla VRAM gerektirir.
# Ayrıca 'peft' ve 'transformers' paketlerinin kurulu olması zorunludur.
ENABLE_LORA_TRAINING=false

# Eğitilecek temel modelin HuggingFace ID'si (Örn: meta-llama/Llama-3.2-1B)
LORA_BASE_MODEL=

# LoRA hiperparametreleri (Düşük VRAM için rank=8 idealdir, daha güçlü ezber için 16-32)
LORA_RANK=8
LORA_ALPHA=16
LORA_DROPOUT=0.05
LORA_EPOCHS=3

# Eğitim Batch boyutu (VRAM yetersizliği / OOM hatası alırsanız 1 veya 2'ye düşürün)
LORA_BATCH_SIZE=4

# true: QLoRA (4-bit nicemleme). VRAM tüketimini inanılmaz düşürür.
# NOT: 'bitsandbytes' kütüphanesini gerektirir (Linux veya Windows WSL2 önerilir).
LORA_USE_4BIT=true

# LoRA adaptör çıktı dizini 
# (Docker kullanıyorsanız 'data/' dizinini kalıcı volume yapmayı unutmayın!)
LORA_OUTPUT_DIR=data/lora_adapters

# ─── Sürekli Öğrenme (Continuous Learning) Döngüsü ───
# true: Hakim (Judge) ve Aktif Öğrenme sinyalleri yeterli sayıya ulaştığında eğitimi otomatik başlatır.
ENABLE_CONTINUOUS_LEARNING=false

# LoRA/QLoRA eğitimini tetiklemek için gereken minimum SFT (Supervised Fine-Tuning) örnek sayısı.
# NOT: 20 değeri sistemin test edilmesi için idealdir. Ancak üretim (Production) ortamında 
# modelin eski bildiklerini unutmaması (Catastrophic Forgetting) için bu değeri 500-1000 yapın.
CONTINUOUS_LEARNING_MIN_SFT_EXAMPLES=20

# DPO/RLHF tercih (preference) dataseti export etmek için gereken minimum çift (pair) sayısı
CONTINUOUS_LEARNING_MIN_PREFERENCE_EXAMPLES=10

# Tek döngüde işlenecek maksimum bekleyen sinyal sayısı (RAM Koruması)
CONTINUOUS_LEARNING_MAX_PENDING_SIGNALS=5000

# Arka plan döngüleri arasındaki minimum bekleme süresi (Varsayılan: 3600 sn = 1 Saat)
CONTINUOUS_LEARNING_COOLDOWN_SECONDS=3600

# Dataset ve manifest çıkış dizini
CONTINUOUS_LEARNING_OUTPUT_DIR=data/continuous_learning

# SFT export formatı (Standartlar: alpaca, sharegpt, jsonl)
CONTINUOUS_LEARNING_SFT_FORMAT=alpaca

# ─── Multimodal AI (Görüş, Ses ve Video, v6.0) ─────────────────────────
# Ajanların ekran görüntülerini analiz etmesini, sizinle konuşmasını ve 
# yüklenen videoları/sesleri anlamasını sağlar.

# true: Görsel (PNG/JPEG) yükleyerek kod üretme (Vision-to-Frontend) veya analiz aktif.
ENABLE_VISION=true

# Kabul edilecek maksimum görsel boyutu (byte) — varsayılan 10485760 (10 MB)
VISION_MAX_IMAGE_BYTES=10485760

# true: Ses/video multimodal işleme hattı aktif
# WSL2/Windows 11 kullanıcıları: install_sidar.sh --enable-audio ile WSLg PulseAudio
# otomatik yapılandırılır ve bu değer true olarak güncellenir.
# Windows 10 veya WSLg yoksa false bırakın.
ENABLE_MULTIMODAL=true

# Görsel/video anlama için kullanılacak yerel Ollama vision modeli.
# KRİTİK: Bu değişken yalnızca ENABLE_MULTIMODAL=true iken ve alan dolu ise geçerlidir.
# Dolu olduğunda install_sidar.sh modeli Ollama'dan otomatik olarak indirir (~7.9 GB).
#
# Önerilen seçenekler:
#   llama3.2-vision   → Meta'nın resmi vision modeli (~7.9 GB) — Önerilir
#   llava             → Genel amaçlı vision modeli (~4.7 GB)
#   llava:13b         → Daha yüksek doğruluk, daha fazla VRAM gerektirir (~8 GB)
#
# VRAM'iniz 8 GB altındaysa llava veya llama3.2-vision:11b-instruct-q4_K_M gibi
# quantize edilmiş bir varyant tercih edin.
#
# Boş bırakılırsa vision modeli indirilmez ve görsel analiz özellikleri pasif kalır.
VISION_MODEL=llama3.2-vision:11b-instruct-q4_K_M

# Maksimum medya (Video/Ses) boyutu (byte) — varsayılan 52428800 (50 MB)
MULTIMODAL_MAX_FILE_BYTES=52428800

# ─── Sesli Asistan (STT & TTS) ──────────────────────────────
# Konuşmadan Metne (Speech-to-Text) sağlayıcısı
VOICE_STT_PROVIDER=whisper

# Whisper model etiketi (base, small, medium, turbo)
# KRİTİK UYARI: Türkçe ses tanıma kalitesi için 'base' modeli çok yetersizdir.
# RTX 30-serisi gibi VRAM'i yeterli modern GPU'larda 'small' veya 'turbo' 
# modelini kullanmanız kesinlikle önerilir (hız düşmeden kalite artar).
WHISPER_MODEL=turbo

# Metinden Sese (Text-to-Speech) sağlayıcısı (auto, pyttsx3, mock)
# NOT: pyttsx3 çevrimdışı ve güvenlidir ancak Türkçe için mekanik/robotik kalabilir.
VOICE_TTS_PROVIDER=auto
VOICE_TTS_VOICE=

# Ajanın konuşma sentezine (TTS) göndereceği minimum karakter parçası.
# Düşük tutmak ajanın tepki süresini hızlandırır, yüksek tutmak tonlamayı düzeltir.
VOICE_TTS_SEGMENT_CHARS=48

# ─── Gerçek Zamanlı Akış (Real-Time Voice Streaming) ────────
# true: Voice activity detection (VAD). Sadece konuştuğunuzda sesi işler.
VOICE_VAD_ENABLED=true

# true: Full-duplex konuşma akışı. Ajan konuşurken araya girip (interrupt) 
# sözünü kesebilir ve yönlendirebilirsiniz. (Üst düzey asistan deneyimi)
VOICE_DUPLEX_ENABLED=true

# Voice websocket bellek üst sınırı (10 MB)
VOICE_WS_MAX_BYTES=10485760

# ─── Slack Entegrasyonu (Operasyonel Bildirimler, v6.0) ──────────
# Ajanların çalışma durumlarını raporlamasını, hata bildirimlerini 
# ve interaktif onay (HITL) taleplerini Slack üzerinden yönetmesini sağlar.

# Slack Bot OAuth Token (xoxb-...)
# api.slack.com üzerinden oluşturulur. 'chat:write', 'files:write' 
# ve 'channels:read' izinleri gereklidir.
SLACK_TOKEN=

# Slack Uygulama Seviyesi Token (xapp-...) (Opsiyonel)
# Ajanın Socket Mode üzerinden Slack kanallarını dinleyip (mention) 
# yanıt vermesi gerekiyorsa doldurun.
SLACK_APP_LEVEL_TOKEN=

# Incoming Webhook URL
# Token yapılandırmasıyla uğraşmadan, sadece basit/tek taraflı bildirim 
# göndermek istiyorsanız burayı doldurun.
SLACK_WEBHOOK_URL=

# Varsayılan hedef kanal veya Kanal ID'si (Örn: #sidar-updates)
# NOT: Ajanların çok sık bildirim gönderebileceğini (gürültü) unutmayın. 
# Özel bir kanal oluşturup ID'sini girmeniz önerilir.
SLACK_DEFAULT_CHANNEL=

# ─── Jira Entegrasyonu (Proje ve Görev Yönetimi, v6.0) ────────
# Ajanların backlog'u okumasını, yeni issue/bug açmasını ve mevcut 
# görevleri güncellemesini sağlar.

# Atlassian Cloud URL (Örn: https://kurumadi.atlassian.net)
JIRA_URL=

# Atlassian hesap e-postası (Cloud kimlik doğrulama için zorunlu)
JIRA_EMAIL=

# API Token
# id.atlassian.com/manage-profile/security/api-tokens adresinden üretin.
# KRİTİK: Bu anahtarın sızmaması için sunucuda güvenli tutulması şarttır.
JIRA_TOKEN=

# Varsayılan Proje ANAHTARI (Project Key)
# ÖNEMLİ: Proje adını değil, kısa kodu girin (Örn: SID, DEV, PROJ).
JIRA_DEFAULT_PROJECT=

# Ajan tarafından oluşturulan kayıtlara eklenecek varsayılan etiket (Label)
# Jira'da "Sidar tarafından açıldı" filtrelemesi yapmak için kullanılır.
JIRA_DEFAULT_LABEL=sidar-ai

# ─── Microsoft Teams Entegrasyonu (v6.0) ──────────────────────
# Ajan bildirimlerini, sistem durumlarını ve onay taleplerini 
# Teams kanallarına iletmek için kullanılır.

# Microsoft Teams Incoming Webhook URL
# Teams Kanalı > Kanalı Yönet > Bağlayıcılar (Connectors) > Incoming Webhook 
# VEYA yeni yöntem: Workflows (Power Automate) üzerinden alınan akış URL'si.
#
# NOT: Sidar, Teams için zengin içerikli 'Adaptive Cards' formatını kullanır. 
# URL'yi kopyalarken başında 'https://' olduğundan emin olun.
TEAMS_WEBHOOK_URL=
