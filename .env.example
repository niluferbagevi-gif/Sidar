# ─────────────────────────────────────────────
# Sidar Project — Çevre Değişkenleri Örneği
# Bu dosyayı .env olarak kopyalayın ve doldurun:
#   cp .env.example .env
#
# Bu şablon platformdan bağımsız güvenli başlangıç değerleri içerir.
# Donanımınıza göre (özellikle GPU ve timeout değerleri) özelleştirin.
# ─────────────────────────────────────────────

# ─── AI Sağlayıcısı ──────────────────────────
# "ollama" (yerel), "gemini" (bulut), "openai" (bulut) veya "anthropic" (bulut)
AI_PROVIDER=ollama

# ─── Ollama ──────────────────────────────────
OLLAMA_URL=http://localhost:11434/api
# Ollama API zaman aşımı (saniye)
# Model boyutu/ağ durumuna göre artırabilirsiniz.
OLLAMA_TIMEOUT=30
CODING_MODEL=qwen2.5-coder:7b
TEXT_MODEL=gemma2:9b

# ─── Google Gemini (opsiyonel) ────────────────
GEMINI_API_KEY=Google AI Studio (aistudio.google.com) üzerinden API key oluşturup buraya yapıştırın
GEMINI_MODEL=gemini-2.5-flash

# ─── OpenAI (opsiyonel) ──────────────────────
OPENAI_API_KEY=platform.openai.com/api-keys üzerinden API key oluşturup buraya yapıştırın
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT=60

# ─── Anthropic Claude (opsiyonel) ─────────────
ANTHROPIC_API_KEY=console.anthropic.com/settings/keys üzerinden API key oluşturup buraya yapıştırın
ANTHROPIC_MODEL=claude-3-5-sonnet-latest
ANTHROPIC_TIMEOUT=60

# ─── Erişim Seviyesi (OpenClaw) ───────────────
# restricted : Yalnızca okuma ve denetim
# sandbox    : Okuma + /temp dizinine yazma
# full       : Tam erişim — yalnızca bilinçli olarak açın
ACCESS_LEVEL=sandbox
# Web UI / API Basic Auth şifresi (opsiyonel, boşsa auth kapalı)
API_KEY=Web UI/API için güçlü bir parola belirleyin (örn: UzunRastgeleSifre123!)

# ─── GitHub (opsiyonel) ───────────────────────
GITHUB_TOKEN=github.com/settings/tokens adresinden repo erişimli Personal Access Token üretip buraya yazın
GITHUB_REPO=kullanici/depo-adi
# GitHub webhook imza doğrulaması için secret
GITHUB_WEBHOOK_SECRET=github webhook ayarlarından üreteceğiniz imza secret değerini buraya yazın

# ─── Donanım & GPU ───────────────────────────
# true = PyTorch CUDA varsa GPU kullan; false = her zaman CPU
USE_GPU=false

# Birden fazla GPU varsa hangi cihaz kullanılsın (0-indexed)
GPU_DEVICE=0

# Çoklu GPU dağıtık mod (çoğu kurulumda false bırakın)
MULTI_GPU=false

# Embedding/model yüklemeleri için maksimum VRAM fraksiyonu (0.1 – 1.0)
GPU_MEMORY_FRACTION=0.8

# FP16 mixed precision → ChromaDB embedding'de VRAM tasarrufu
# Yeni nesil GPU'larda true tercih edilebilir; sorun yaşarsanız false kullanın
GPU_MIXED_PRECISION=false

# ─── HuggingFace ─────────────────────────────
# Model ilk indirildikten sonra HF_HUB_OFFLINE=1 yapın:
# → Her açılışta internet kontrolü yapmaz, cache'den hızlıca yükler (~1 dk tasarruf)
# İlk kurulumda veya model güncellemek istediğinizde 0 yapın.
HF_TOKEN=huggingface.co/settings/tokens adresinden Read token üretip buraya yazın
HF_HUB_OFFLINE=0

# ─── Uygulama ────────────────────────────────
MAX_MEMORY_TURNS=20
# Özetleme sonrası ham bellekte tutulacak son konuşma turu
MEMORY_SUMMARY_KEEP_LAST=4
RESPONSE_LANGUAGE=tr
DEBUG_MODE=false
# Ortam profili (development/staging/production)
SIDAR_ENV=development

# ReviewerAgent doğrulama aşamasında çalıştırılacak test komutu
REVIEWER_TEST_COMMAND=python -m pytest

# ─── Loglama ─────────────────────────────────
LOG_LEVEL=INFO
# Log dosyası yolu (proje köküne göre)
LOG_FILE=logs/sidar_system.log
# Tek log dosyası maksimum boyutu (byte) — varsayılan 10 MB
LOG_MAX_BYTES=10485760
# Yedek log dosyası sayısı
LOG_BACKUP_COUNT=5

# ─── ReAct Döngüsü ───────────────────────────
MAX_REACT_STEPS=10
# İhtiyaca göre artırın (büyük görevler/düşük donanım için)
REACT_TIMEOUT=60
# Alt ajanların kendi içlerinde maksimum ReAct adımı
SUBTASK_MAX_STEPS=5
# AutoHandle kısa komutlarında (örn .status) blocking işlem timeout
AUTO_HANDLE_TIMEOUT=12

# ─── LLM Retry Ayarları ───────────────────────
# LLM sağlayıcı çağrılarında maksimum yeniden deneme sayısı
LLM_MAX_RETRIES=2
# Exponential backoff başlangıç gecikmesi (saniye)
LLM_RETRY_BASE_DELAY=0.4
# Exponential backoff için üst gecikme sınırı (saniye)
LLM_RETRY_MAX_DELAY=4.0

# ─── Gözlemlenebilirlik (OpenTelemetry) ─────
ENABLE_TRACING=false
OTEL_EXPORTER_ENDPOINT=http://localhost:4317

# ─── Redis (Kalıcı Rate Limiting) ───────────
REDIS_URL=redis://redis:6379/0

# ─── API Hız Sınırları (Rate Limiting) ───────
# 60 saniyelik penceredeki istek limitleri
RATE_LIMIT_WINDOW=60
RATE_LIMIT_CHAT=20
RATE_LIMIT_MUTATIONS=60
RATE_LIMIT_GET_IO=30

# ─── Web Arama ───────────────────────────────
# auto, duckduckgo, tavily veya google
SEARCH_ENGINE=auto
TAVILY_API_KEY=app.tavily.com üzerinden API key oluşturup buraya yapıştırın
GOOGLE_SEARCH_API_KEY=Google Cloud Console'da Custom Search JSON API key oluşturup buraya yazın
GOOGLE_SEARCH_CX=programmablesearchengine.google.com üzerinden Search Engine ID (cx) değerini buraya yazın

# DuckDuckGo arama sonucu sayısı (1-10 arası önerilir)
WEB_SEARCH_MAX_RESULTS=5
# URL içerik çekme zaman aşımı (saniye)
WEB_FETCH_TIMEOUT=15
# URL içerik maksimum karakter sınırı
WEB_FETCH_MAX_CHARS=12000
# Yeni ad (öncelikli): scrape bağlam limiti
WEB_SCRAPE_MAX_CHARS=12000

# ─── Paket Bilgi ─────────────────────────────
# PyPI/npm/GitHub API zaman aşımı (saniye)
PACKAGE_INFO_TIMEOUT=12
# Paket sorgu cache süresi (saniye)
PACKAGE_INFO_CACHE_TTL=1800

# ─── RAG — Belge Deposu ──────────────────────
# Belge depolama dizini (proje köküne göre)
RAG_DIR=data/rag
# Arama sonucu sayısı
RAG_TOP_K=3
# Chunk boyutu (karakter)
RAG_CHUNK_SIZE=1000
# Chunk örtüşme miktarı (karakter)
RAG_CHUNK_OVERLAP=200
# Büyük dosya eşiği (karakter) — bu sınırı geçen dosyaları RAG'a ekleme önerilir
RAG_FILE_THRESHOLD=20000

# ─── Bellek Şifrelemesi ──────────────────────
# Boş bırakılırsa şifreleme devre dışı (varsayılan — önerilen genel kullanım).
# Kurumsal/hassas veri için Fernet anahtarı üretin:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Üretilen anahtarı buraya yapıştırın (44 karakter, = ile biter):
MEMORY_ENCRYPTION_KEY=Kurumsal kullanımda Fernet anahtarı üretip buraya yazın; kişisel kullanımda boş bırakabilirsiniz

# ─── Web Arayüzü ─────────────────────────────
# Dinlenecek adres (0.0.0.0 = tüm arayüzler, localhost = yalnızca yerel)
WEB_HOST=0.0.0.0
# Port numarası (7860 AI uygulamaları için yaygın tercih)
WEB_PORT=7860
# GPU web servisi portu (docker-compose sidar-web-gpu servisi için)
WEB_GPU_PORT=7861

# ─── Docker REPL Sandbox ──────────────────────
# CodeManager'ın kod çalıştırma sandbox'ında kullanacağı Docker imajı
# CPU ortamı için python:3.11-alpine önerilir (küçük boyut, hızlı başlangıç)
DOCKER_PYTHON_IMAGE=python:3.11-alpine
# Maksimum Docker sandbox çalışma süresi (saniye) — sonsuz döngü koruması
DOCKER_EXEC_TIMEOUT=10
DOCKER_RUNTIME=
DOCKER_ALLOWED_RUNTIMES=,runc,runsc,kata-runtime

# ─── Sandbox Kaynak Kotaları (gelişmiş, opsiyonel) ───
# Aşağıdaki değerler config.py::SANDBOX_LIMITS içinde kullanılır ve CodeManager
# tarafından Docker run çağrısına aktarılır. Varsayılanlar güvenli/dengeli seçilmiştir.
# Yüksek performanslı görevlerde artırabilir; kısıtlı ortamlarda düşürebilirsiniz.
SANDBOX_MEMORY=256m
SANDBOX_CPUS=0.5
SANDBOX_NETWORK=none
SANDBOX_PIDS_LIMIT=64
SANDBOX_TIMEOUT=10