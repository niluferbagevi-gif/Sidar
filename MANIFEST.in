include README.md
include CLAUDE.md
include LICENSE
include .env.example
include pytest.ini
include pyproject.toml
include environment.yml
include docker-compose.yml
include alembic.ini

recursive-include docker *
recursive-include migrations *.py
recursive-include docs *.md *.txt
recursive-include tests *.py

global-exclude __pycache__
global-exclude *.pyc
global-exclude *.pyo
global-exclude *.egg-info
