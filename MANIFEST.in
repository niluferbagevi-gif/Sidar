# MANIFEST.in — PyPI kaynak dağıtımına dahil edilecek dosyalar
# sdist (python -m build --sdist) sırasında kullanılır.

# Konfigürasyon ve ortam şablonları
include .env.example
include alembic.ini
include environment.yml
include requirements.txt

# Docker
include Dockerfile
include docker-compose.yml

# Kurulum
include install_sidar.sh

# Belgeler ve lisans
include CHANGELOG.md
include README.md

# Migrasyon dosyaları
recursive-include migrations *.py *.ini *.cfg

# Docs
recursive-include docs *

# Data dizini (şema/seed dosyaları — büyük binary veriler hariç)
recursive-include data *.sql *.json *.yaml *.yml
prune data/lora_adapters
prune data/continuous_learning

# Prune — kaynak dağıtıma dahil edilmemesi gerekenler
prune .git
prune __pycache__
prune *.egg-info
global-exclude *.pyc *.pyo *.pyd
global-exclude .DS_Store
global-exclude *.log
