[run]
branch = True
parallel = True
source =
    agent
    core
    managers
    plugins
    main.py
    web_server.py
omit =
    tests/*
    tests/sidar_plugin_*
    */tests/sidar_plugin_*
    */plug_auto_discover*
    */plug_bad_compile*
    conftest.py
    migrations/*
    scripts/*
    docs/*
    */__pycache__/*
    */site-packages/*
    .venv/*
    venv/*
    .tox/*
    .env
    setup.py

[report]
fail_under = 90
show_missing = True
skip_covered = True
precision = 2
# Raporlama sırasında göz ardı edilecek dosya desenleri
exclude_lines =
    pragma: no cover
    def __repr__
    def __str__
    raise AssertionError
    raise NotImplementedError
    if __name__ == .__main__.:
    if TYPE_CHECKING:
    if typing.TYPE_CHECKING:
    @abstractmethod
    @abstractproperty
    if 0:
    if False:
    pass

[html]
directory = htmlcov

[xml]
output = coverage.xml